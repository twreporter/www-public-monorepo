// This file is automatically generated by Keystone, do not modify it manually.
// Modify your Keystone config when you want to change this.

datasource mysql {
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
  provider          = "mysql"
}

generator client {
  provider = "prisma-client-js"
}

model ReporterSystemUser {
  id        Int       @id @default(autoincrement())
  name      String    @default("")
  email     String    @unique @default("")
  password  String
  role      String
  createdAt DateTime? @default(now())
  updatedAt DateTime? @updatedAt
}

model Post {
  id                        Int                @id @default(autoincrement())
  slug                      String             @unique @default("")
  title                     String             @default("")
  subtitle                  String             @default("")
  state                     String?            @default("draft")
  publishedDate             DateTime?
  updatedDate               DateTime?
  authors                   Author[]           @relation("Author_posts")
  authorsJSON               Json?              @default("[]")
  heroImage                 Photo?             @relation("Post_heroImage", fields: [heroImageId], references: [id])
  heroImageId               Int?               @map("heroImage")
  heroSize                  String?            @default("medium")
  heroCaption               String             @default("")
  content                   Json?
  postFollowups             PostFollowup[]     @relation("Post_postFollowups")
  subcategories             Subcategory[]      @relation("Post_subcategories")
  subcategoriesOrderJson    Json?              @default("[]")
  style                     String?            @default("default")
  relatedTopics             Topic[]            @relation("Post_relatedTopics")
  relatedTopicsOrderJson    Json?              @default("[]")
  copyright                 String?            @default("copyrighted")
  tags                      Tag[]              @relation("Post_tags")
  tagsOrderJson             Json?              @default("[]")
  relatedPosts              Post[]             @relation("Post_beenRelatedPosts")
  relatedPostsOrderJson     Json?              @default("[]")
  reviewWord                String             @default("")
  ogTitle                   String             @default("")
  ogDescription             String             @default("")
  ogImage                   Photo?             @relation("Post_ogImage", fields: [ogImageId], references: [id])
  ogImageId                 Int?               @map("ogImage")
  pushNotifications         PushNotification[] @relation("PushNotification_post")
  newPageTargetBlank        Boolean            @default(false)
  isFeatured                Boolean            @default(false)
  beenRelatedPosts          Post[]             @relation("Post_beenRelatedPosts")
  beenRelatedPostsOrderJson Json?              @default("[]")
  createdAt                 DateTime?          @default(now())
  updatedAt                 DateTime?          @updatedAt
  from_Topic_posts          Topic[]            @relation("Topic_posts")
  from_Category_posts       Category[]         @relation("Category_posts")
  from_Review_post          Review[]           @relation("Review_post")

  @@index([title])
  @@index([state])
  @@index([publishedDate])
  @@index([heroImageId])
  @@index([ogImageId])
}

model Photo {
  id                         Int           @id @default(autoincrement())
  name                       String        @default("")
  imageFile_id               String?
  imageFile_filesize         Int?
  imageFile_width            Int?
  imageFile_height           Int?
  imageFile_extension        String?
  authors                    Author[]      @relation("Photo_authors")
  IPTC                       Json?
  copyright                  String?       @default("copyrighted")
  keywords                   String        @default("")
  createdAt                  DateTime?     @default(now())
  updatedAt                  DateTime?     @updatedAt
  from_Post_heroImage        Post[]        @relation("Post_heroImage")
  from_Post_ogImage          Post[]        @relation("Post_ogImage")
  from_Author_avatar         Author[]      @relation("Author_avatar")
  from_Author_ogImage        Author[]      @relation("Author_ogImage")
  from_Topic_heroImage       Topic[]       @relation("Topic_heroImage")
  from_Topic_mobileHeroImage Topic[]       @relation("Topic_mobileHeroImage")
  from_Topic_ogImage         Topic[]       @relation("Topic_ogImage")
  from_Category_ogImage      Category[]    @relation("Category_ogImage")
  from_Subcategory_ogImage   Subcategory[] @relation("Subcategory_ogImage")
  from_Tag_ogImage           Tag[]         @relation("Tag_ogImage")

  @@index([name])
}

model Author {
  id                 Int       @id @default(autoincrement())
  slug               String    @unique @default("")
  name               String    @default("")
  email              String    @default("")
  title              String    @default("")
  avatar             Photo?    @relation("Author_avatar", fields: [avatarId], references: [id])
  avatarId           Int?      @map("avatar")
  ogTitle            String    @default("")
  ogDescription      String    @default("")
  ogImage            Photo?    @relation("Author_ogImage", fields: [ogImageId], references: [id])
  ogImageId          Int?      @map("ogImage")
  posts              Post[]    @relation("Author_posts")
  createdAt          DateTime? @default(now())
  updatedAt          DateTime? @updatedAt
  from_Photo_authors Photo[]   @relation("Photo_authors")

  @@index([name])
  @@index([avatarId])
  @@index([ogImageId])
}

model Topic {
  id                  Int                  @id @default(autoincrement())
  slug                String               @unique @default("")
  title               String               @default("")
  subtitle            String               @default("")
  headline            String               @default("")
  topicName           String               @default("")
  titlePosition       String?              @default("bottom")
  state               String?              @default("draft")
  publishedDate       DateTime?
  updatedDate         DateTime?
  posts               Post[]               @relation("Topic_posts")
  postLayout          TopicPostLayoutType? @default(row)
  postBackgroundColor String?
  heroImage           Photo?               @relation("Topic_heroImage", fields: [heroImageId], references: [id])
  heroImageId         Int?                 @map("heroImage")
  mobileHeroImage     Photo?               @relation("Topic_mobileHeroImage", fields: [mobileHeroImageId], references: [id])
  mobileHeroImageId   Int?                 @map("mobileHeroImage")
  ogTitle             String               @default("")
  ogDescription       String               @default("")
  ogImage             Photo?               @relation("Topic_ogImage", fields: [ogImageId], references: [id])
  ogImageId           Int?                 @map("ogImage")
  relatedPosts        Post[]               @relation("Post_relatedTopics")
  createdAt           DateTime?            @default(now())
  updatedAt           DateTime?            @updatedAt

  @@index([title])
  @@index([state])
  @@index([publishedDate])
  @@index([heroImageId])
  @@index([mobileHeroImageId])
  @@index([ogImageId])
}

model Category {
  id            Int           @id @default(autoincrement())
  slug          String        @unique @default("")
  name          String        @unique @default("")
  subcategories Subcategory[] @relation("Subcategory_category")
  sortOrder     Int?          @unique
  ogTitle       String        @default("")
  ogDescription String        @default("")
  ogImage       Photo?        @relation("Category_ogImage", fields: [ogImageId], references: [id])
  ogImageId     Int?          @map("ogImage")
  posts         Post[]        @relation("Category_posts")
  createdAt     DateTime?     @default(now())
  updatedAt     DateTime?     @updatedAt

  @@index([ogImageId])
}

model Subcategory {
  id            Int       @id @default(autoincrement())
  slug          String    @unique @default("")
  name          String    @unique @default("")
  category      Category? @relation("Subcategory_category", fields: [categoryId], references: [id])
  categoryId    Int?      @map("category")
  nameForCMS    String    @default("")
  sortOrder     Int?      @unique
  ogTitle       String    @default("")
  ogDescription String    @default("")
  ogImage       Photo?    @relation("Subcategory_ogImage", fields: [ogImageId], references: [id])
  ogImageId     Int?      @map("ogImage")
  posts         Post[]    @relation("Post_subcategories")
  createdAt     DateTime? @default(now())
  updatedAt     DateTime? @updatedAt

  @@index([categoryId])
  @@index([ogImageId])
}

model Tag {
  id              Int       @id @default(autoincrement())
  slug            String    @unique @default("")
  name            String    @unique @default("")
  ogTitle         String    @default("")
  ogDescription   String    @default("")
  ogImage         Photo?    @relation("Tag_ogImage", fields: [ogImageId], references: [id])
  ogImageId       Int?      @map("ogImage")
  posts           Post[]    @relation("Post_tags")
  createdAt       DateTime? @default(now())
  updatedAt       DateTime? @updatedAt
  from_Latest_tag Latest[]  @relation("Latest_tag")

  @@index([ogImageId])
}

model PostFollowup {
  id            Int       @id @default(autoincrement())
  title         String    @default("")
  publishedDate DateTime?
  summary       String    @default("")
  posts         Post[]    @relation("Post_postFollowups")
  createdAt     DateTime? @default(now())
  updatedAt     DateTime? @updatedAt

  @@index([title])
  @@index([publishedDate])
}

model PushNotification {
  id          Int       @id @default(autoincrement())
  title       String    @default("")
  link        String    @default("")
  labelForCMS String    @default("")
  publishedAt DateTime
  channel     Json      @default("[\"webpush\",\"telegram\"]")
  post        Post?     @relation("PushNotification_post", fields: [postId], references: [id])
  postId      Int?      @map("post")
  createdAt   DateTime? @default(now())
  updatedAt   DateTime? @updatedAt

  @@index([postId])
}

model Latest {
  id    Int  @id @default(autoincrement())
  tag   Tag? @relation("Latest_tag", fields: [tagId], references: [id])
  tagId Int? @map("tag")
  order Int?

  @@index([tagId])
}

model Review {
  id     Int   @id @default(autoincrement())
  post   Post? @relation("Review_post", fields: [postId], references: [id])
  postId Int?  @map("post")
  order  Int?

  @@index([postId])
}

enum TopicPostLayoutType {
  row
  column
}
